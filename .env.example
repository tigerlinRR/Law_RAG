# Copy to .env and adjust. All services are local; no external network calls.

# --- Postgres + pgvector (docker: lawrag-db) ---
PG_HOST=localhost
PG_PORT=5434
PG_DB=lawrag
PG_USER=lawrag
PG_PASSWORD=change-me

# --- Embedding service (docker: lawrag-embed, vLLM OpenAI-compatible) ---
EMBED_BASE_URL=http://localhost:8010/v1
EMBED_MODEL=qwen3-embed
EMBED_DIM=1024

# --- LLM (docker: lawrag-llm, vLLM Qwen3.6-35B, 32k context) — for due diligence ---
LLM_BASE_URL=http://localhost:8012/v1
LLM_MODEL=qwen3.6
LLM_MAX_CTX_CHARS=90000

# --- Reranker (docker: lawrag-rerank, vLLM cross-encoder) ---
RERANK_BASE_URL=http://localhost:8011
RERANK_MODEL=bge-rerank
RERANK_ENABLED=1

# --- Chunking ---
CHUNK_CHARS=1200
CHUNK_OVERLAP=150

# --- Retrieval ---
TOPK_VECTOR=20
TOPK_TEXT=20
RERANK_CANDIDATES=30
TOPK_FINAL=8
